{
  "name": "gitpulse",
  "private": true,
  "version": "0.3.0",
  "description": "Local-first Git repository analytics desktop app.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Boblebol/GitPulse.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "site:dev": "vite --config vite.site.config.ts",
    "site:build": "tsc -p tsconfig.site.json && vite build --config vite.site.config.ts",
    "site:preview": "vite preview --config vite.site.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.97.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.8.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
